---
/**
 * Contact page — /ko/contact/ and /en/contact/
 */
import Layout from '../../components/Layout.astro';
import { getLang, t } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'ko' } },
    { params: { lang: 'en' } },
  ];
}

const lang = getLang(Astro.params.lang);
const email = 'infodeskline@gmail.com';
---

<Layout
  lang={lang}
  title={t(lang, 'contact.title')}
  description={t(lang, 'contact.subtitle')}
>
  <section class="section contact-page">
    <div class="container">
      <div class="contact-card glass-card">
        <h1 class="contact-title">{t(lang, 'contact.title')}</h1>
        <p class="contact-subtitle">{t(lang, 'contact.subtitle')}</p>

        <div class="email-row">
          <span class="email-label">{t(lang, 'contact.emailLabel')}</span>
          <a href={`mailto:${email}`} class="email-address">{email}</a>
        </div>

        <a
          href={`mailto:${email}`}
          class="btn btn-primary contact-btn"
        >
          {t(lang, 'contact.emailButton')}
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-page {
    display: flex;
    align-items: center;
    min-height: calc(80vh - var(--gnb-height));
    padding-bottom: var(--space-3xl);
  }

  .container {
    width: 100%;
  }

  .contact-card {
    max-width: 480px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-lg);
  }

  .contact-title {
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .contact-subtitle {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-top: calc(-1 * var(--space-sm));
  }

  .email-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    width: 100%;
  }

  .email-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
  }

  .email-address {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-accent);
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color var(--duration-fast) var(--ease-smooth);
  }

  .email-address:hover {
    color: var(--color-accent-hover);
  }

  .contact-btn {
    width: 100%;
    justify-content: center;
  }
</style>
